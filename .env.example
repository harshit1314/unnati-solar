# ============================================================
#  SolarHub — Environment Variables
#  Copy this file to .env.local and fill in real values
#  NEVER commit .env.local to git
# ============================================================

# --- Supabase (required for lead storage + CRM) ---
# Get from: https://supabase.com/dashboard/project/<your-project>/settings/api
REACT_APP_SUPABASE_URL=your-project-url-here
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — used only in CRM (admin operations)
# Keep this private — do NOT commit or share
REACT_APP_SUPABASE_SERVICE_KEY=your-service-role-key-here

# --- CRM Access (simple password gate) ---
REACT_APP_CRM_PASSWORD=your-password-here

# --- WhatsApp (lead forwarding) ---
REACT_APP_WHATSAPP_NUMBER=your-whatsapp-number-here

# --- Telegram Notifications (lead alerts to owner) ---
# Create a bot via @BotFather on Telegram → get token
# Get your chat ID via @userinfobot
REACT_APP_TELEGRAM_BOT_TOKEN=your-bot-token-here
REACT_APP_TELEGRAM_CHAT_ID=your-chat-id-here

# --- Analytics (optional, site works without these) ---
REACT_APP_GA_ID=G-XXXXXXXXXX
REACT_APP_CLARITY_ID=your-clarity-id
